{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -q 'git push' && bash scripts/check-i18n.sh || true",
            "timeout": 15,
            "statusMessage": "Checking i18n translations..."
          }
        ]
      }
    ]
  }
}
